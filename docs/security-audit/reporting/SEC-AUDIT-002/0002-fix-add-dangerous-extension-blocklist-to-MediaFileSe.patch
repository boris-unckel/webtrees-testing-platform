From 3bb05b15d4032e2deaf259ec26b58879e6a597ed Mon Sep 17 00:00:00 2001
From: boris-unckel <bu.githubcom@mail.unckel.net>
Date: Thu, 9 Apr 2026 08:44:57 +0200
Subject: [PATCH 2/3] fix: add dangerous-extension blocklist to
 MediaFileService::uploadFile()

MediaFileService::uploadFile() accepted any file extension, while
its sibling UploadMediaAction::handle() enforced a blocklist for
.php, .pl, .cgi, .bash, .sh, .bat, .exe, .com, .htm, .html, .shtml.

An editor could bypass the blocklist by uploading via
CreateMediaObjectAction or AddMediaFileAction instead of UploadMediaAction.

This mirrors UploadMediaAction's regex into uploadFile() so both
upload pipelines enforce the same extension restrictions.

SEC-AUDIT-002

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 app/Services/MediaFileService.php | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/app/Services/MediaFileService.php b/app/Services/MediaFileService.php
index a4e6ba3c0a..3b5147bc5a 100644
--- a/app/Services/MediaFileService.php
+++ b/app/Services/MediaFileService.php
@@ -44,6 +44,7 @@ use function explode;
 use function intdiv;
 use function min;
 use function pathinfo;
+use function preg_match;
 use function sha1;
 use function sort;
 use function str_contains;
@@ -166,6 +167,13 @@ class MediaFileService
                     $file = $uploaded_file->getClientFilename();
                 }
 
+                // Do not allow obvious script files.
+                if (preg_match('/(\.(php|pl|cgi|bash|sh|bat|exe|com|htm|html|shtml))$/i', $file, $match)) {
+                    FlashMessages::addMessage(I18N::translate('Filenames are not allowed to have the extension "%s".', $match[1]));
+
+                    return '';
+                }
+
                 // The folder
                 $folder = strtr($folder, ['\\' => '/']);
                 $folder = trim($folder, '/');
