# webtrees-tests Container-Stack — Umgebungsvariablen
#
# Passwoerter werden automatisch durch `make up` generiert
# (scripts/generate-passwords.sh). Leere Werte = noch nicht generiert.
# Manuelle Werte werden bei erneutem `make up` beibehalten.
# `make clean` setzt alle Passwoerter zurueck.

# MySQL — Test-Stack
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=webtrees_test
MYSQL_USER=webtrees
MYSQL_PASSWORD=

# MySQL — Security-Track
MYSQL_SECURITY_ROOT_PASSWORD=
MYSQL_SECURITY_PASSWORD=

# webtrees Applikation
WEBTREES_ADMIN_PASSWORD=
WEBTREES_TEST_USER_PASSWORD=
WEBTREES_BASE_URL=http://localhost:8080

# OpenTelemetry
OTEL_PHP_AUTOLOAD_ENABLED=true
OTEL_SERVICE_NAME=webtrees
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SDK_DISABLED=false
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# --- Upstream-Source ---
# Pfad zum webtrees-Checkout (Default: ./upstream/webtrees, automatisch geklont)
# WEBTREES_SOURCE=./upstream/webtrees
# Repository-URL (fuer Forks)
# WEBTREES_REPO=https://github.com/fisharebest/webtrees.git
# Branch, Tag oder Ref
# WEBTREES_REF=main
