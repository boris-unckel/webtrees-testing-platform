# webtrees-tests Container-Stack — Umgebungsvariablen
# Kopieren nach .env und ggf. anpassen

# MySQL
MYSQL_ROOT_PASSWORD=webtrees_test
MYSQL_DATABASE=webtrees_test
MYSQL_USER=webtrees
MYSQL_PASSWORD=webtrees_test

# webtrees
WEBTREES_BASE_URL=http://localhost:8080

# OpenTelemetry
OTEL_PHP_AUTOLOAD_ENABLED=true
OTEL_SERVICE_NAME=webtrees
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SDK_DISABLED=false
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# --- Upstream-Source ---
# Pfad zum webtrees-Checkout (Default: ./upstream/webtrees, automatisch geklont)
# WEBTREES_SOURCE=./upstream/webtrees
# Repository-URL (für Forks)
# WEBTREES_REPO=https://github.com/fisharebest/webtrees.git
# Branch, Tag oder Ref
# WEBTREES_REF=main
