<!--
  Teststufe 1 — Komponententest (PHPUnit)
  SQLite in-memory, wie webtrees Core selbst
  Testet isolierte Klassen ohne Datenbankabhängigkeit
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd"
         bootstrap="/var/www/html/vendor/autoload.php"
         cacheDirectory="/tmp/phpunit-cache"
         colors="true"
         failOnRisky="true"
         failOnWarning="false"
         beStrictAboutTestsThatDoNotTestAnything="true">

    <testsuites>
        <testsuite name="unit">
            <!-- webtrees-eigene Unit-Tests. Upstream-Layout seit dem PSR-4-Umbau
                 (Commit d0160720fb, nach Tag 2.2.6): tests/app -> tests/Unit,
                 Namespace Fisharebest\Webtrees\Tests\Unit (autoload-dev: Tests\ -> tests/). -->
            <directory>/var/www/html/tests/Unit</directory>
        </testsuite>
    </testsuites>

    <php>
        <!-- R4 (Phase K): siehe phpunit-integration.xml. log_errors im
             PHPUnit-Kontext erzeugt eine zweite "PHP Deprecated:"-Kopie auf
             stderr (statt den File-Log zu schreiben). Deshalb scoped
             deaktiviert; display_errors=On bleibt aktiv und druckt Errors
             einmal. -->
        <ini name="log_errors" value="0"/>
    </php>

    <source>
        <include>
            <directory suffix=".php">/var/www/html/app</directory>
        </include>
    </source>

    <coverage>
        <report>
            <html outputDirectory="/artifacts/layer2/coverage-html"/>
            <clover outputFile="/artifacts/layer2/coverage.xml"/>
        </report>
    </coverage>
</phpunit>
