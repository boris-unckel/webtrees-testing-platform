# Laufzeit-Artefakte (Coverage, Layer3-Reports, Trace-Exporte, …)
artifacts/*
# Security-Audit-Artefakte (Sweep-Läufe + Deep-Dive-Ergebnisse) sind kein Laufzeit-Output,
# sondern der versionierte Audit-Trail — Ausnahme vom generellen artifacts/-Ignore.
!artifacts/security-audit/
# Runtime-Trace-Dateien werden vom SecurityTraceModule geschrieben — bleiben ignored.
artifacts/security-audit/traces/*
!artifacts/security-audit/traces/.gitkeep

# Upstream-Clone (automatisch via make setup / scripts/clone-upstream.sh)
upstream/

# Generierte Fixtures (aus Template erzeugt via generate-privacy-fixture.sh)
fixtures/privacy-test.ged

# Credentials & lokale Overrides
.env
.env.local
.env.*.local

# Claude Code — lokale/ephemere Dateien (user-spezifische Permissions + Laufzeit-Locks).
# Projekt-geteilte Artefakte wie .claude/settings.json, .claude/commands/ und
# .claude/agents/ bleiben bewusst trackable (kein pauschales .claude/-Ignore).
.claude/settings.local.json
.claude/*.lock

# macOS
.DS_Store

# vim
*.swp
*.swo

# VS Code
.vscode/

# JetBrains
.idea/
